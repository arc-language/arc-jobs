{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**/*.js", "bin/**/*.js"]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noRedundantUseStrict": "off",
				"noTemplateCurlyInString": "off"
			},
			"style": {
				"useExponentiationOperator": "warn",
				"useNodejsImportProtocol": "warn",
				"useTemplate": "off"
			}
		}
	},
	"assist": {
		"enabled": false
	}
}
