{
  "name": "@arc-lang/arc-jobs",
  "version": "0.1.0",
  "description": "Production background jobs for Arc — SQLite, Redis, and memory adapters with scheduling, deduplication (@unique), progress tracking (@progress), and an admin dashboard",
  "main": "src/index.js",
  "types": "src/types/index.d.ts",
  "bin": {
    "arc-jobs": "./bin/arc-jobs.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./adapters/memory": "./src/adapters/memory.js",
    "./adapters/sqlite": "./src/adapters/sqlite.js",
    "./adapters/redis": "./src/adapters/redis.js",
    "./dashboard": "./src/dashboard/handler.js"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test tests/",
    "test:watch": "bun test --watch tests/",
    "test:coverage": "bun test --coverage tests/",
    "lint": "biome check --error-on-warnings src/ bin/"
  },
  "keywords": [
    "arc",
    "arc-lang",
    "arc-language",
    "jobs",
    "queue",
    "background-jobs",
    "job-queue",
    "task-queue",
    "celery",
    "bullmq",
    "sqlite",
    "redis",
    "bun",
    "cron",
    "scheduler",
    "deduplication",
    "progress",
    "dashboard"
  ],
  "author": "Arc Contributors",
  "funding": "https://github.com/sponsors/arc-language",
  "repository": {
    "type": "git",
    "url": "https://github.com/arc-language/arc-jobs.git"
  },
  "homepage": "https://arc-language.dev/docs/jobs",
  "bugs": {
    "url": "https://github.com/arc-language/arc-jobs/issues"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "ioredis": ">=5.0.0",
    "better-sqlite3": ">=9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
